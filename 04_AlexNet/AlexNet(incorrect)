device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Device : {device}")

class ImageTransform():
  def __init__(self, resize, mean, std):
    self.ImageTransform = {
        "train" : transforms.Compose([
            # 1. 무작위 크기로 자르고 리사이즈 (기존 유지)
            transforms.RandomResizedCrop(resize, scale=(0.6, 1.0)),

            # 2. 좌우 반전 (기존 유지)
            transforms.RandomHorizontalFlip(p=0.5),

            # 3. [추가] 최대 15도까지 무작위 회전
            transforms.RandomRotation(degrees=15),

            # 4. [추가] 밝기, 대비, 채도, 색조를 무작위로 미세하게 변경
            transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2, hue=0.1),

            # 5. 파이토치 텐서형태로 변환 및 정규화
            transforms.ToTensor(),
            transforms.Normalize(mean, std)
        ]),
        "val" :transforms.Compose([
            transforms.Resize(resize),
            transforms.CenterCrop(resize),
            transforms.ToTensor(),
            transforms.Normalize(mean, std)
        ])
    }

  def __call__(self, img, phase):
    return self.ImageTransform[phase](img)


# 이미지 데이터 셋 클래스
class Dog_Cat_dataset(Dataset):
  def __init__(self, file_list, transform=None, phase='train'):
    self.file_list = file_list
    self.transform = transform
    self.phase = phase

  def __len__(self):
    return len(self.file_list)

  def __getitem__(self, idx):
    img_path = self.file_list[idx]
    img = Image.open(img_path).convert("RGB")
    img_transform = self.transform(img, self.phase)
    label = img_path.split('/')[-1].split('.')[0].split('_')[0]

    if label == "dog":
      label = 0
    elif label == "cat":
      label = 1
    else:
      label =0

    return img_transform, label

class AlexNet(nn.Module):
  def __init__(self): 
    super(AlexNet, self).__init__()
    self.features = nn.Sequential(
        nn.Conv2d(3, 48, kernel_size=11, stride=4),
        nn.ReLU(inplace=True),
        nn.MaxPool2d(kernel_size=3, stride=2),
        # 32, 48, 27, 27
        nn.Conv2d(48, 64, kernel_size=5, stride=1, padding=2),
        nn.ReLU(inplace=True),
        nn.MaxPool2d(kernel_size=3, stride=2),
        # 32, 64, 13, 13
        nn.Conv2d(64, 128, kernel_size=3, stride=1, padding=1),
        nn.ReLU(inplace=True),
        # 32, 128, 13, 13
        nn.Conv2d(128, 192, kernel_size=3, stride=1, padding=1),
        nn.ReLU(inplace=True),
        # 32, 192, 13, 13
        nn.Conv2d(192, 128, kernel_size=3, stride=1, padding=1),
        nn.ReLU(inplace=True),
        nn.MaxPool2d(kernel_size=3, stride=2)
        # 32, 128, 6, 6
    )
    self.classifier = nn.Sequential(
        nn.Dropout(p=0.5),
        nn.Linear(6*6*128, 1024),
        nn.ReLU(inplace=True),
        nn.Dropout(p=0.5),
        nn.Linear(1024, 2)
    )
  def forward(self, x):
    out = self.features(x)
    out = torch.flatten(out, 1)
    out = self.classifier(out)
    return out

def train_model(model, dataloader_dict, criterion, optimizer, num_epochs):
    since = time.time()

    for epoch in range(num_epochs):
        print('Epoch {}/{}'.format(epoch+1, num_epochs))
        print('-'*20)

        for phase in ['train', 'val']:
            if phase == 'train':
                model.train()
            elif phase == 'val':
                model.eval()

            # 🟢 [위치 변경] 매 에포크, 매 페이즈가 시작될 때마다 누적 변수를 0으로 리셋합니다!
            epoch_loss = 0.0
            epoch_corrects = 0

            # 배치 단위로 학습 진행
            for inputs, labels in tqdm(dataloader_dict[phase]):
                inputs = inputs.to(device)
                labels = labels.to(device)

                optimizer.zero_grad()

                with torch.set_grad_enabled(phase == 'train'):
                    outputs = model(inputs)
                    _, preds = torch.max(outputs, 1)
                    loss = criterion(outputs, labels)

                    if phase == 'train':
                        loss.backward()
                        optimizer.step()

                # 순수 배치의 오차 총합과 정답 수 누적
                epoch_loss += loss.item() * inputs.size(0)
                epoch_corrects += torch.sum(preds == labels.data)

            # 🟢 [위치 변경] 배치가 다 돌고 난 후(for문 밖에서) 에포크 전체의 평균을 계산합니다!
            dataset_size = len(dataloader_dict[phase].dataset)
            epoch_loss_avg = epoch_loss / dataset_size
            epoch_acc_avg = epoch_corrects.double() / dataset_size

            # 🖨️ 한 에포크당 딱 1번만 깔끔하게 평균 Loss와 정확도(비율)를 출력합니다.
            print("{} Loss : {:.4f}   Acc : {:.4f}".format(phase, epoch_loss_avg, epoch_acc_avg))

    time_elapsed = time.time() - since
    print('Training complete in {:.0f}m {:.0f}s'.format(time_elapsed // 60, time_elapsed % 60))

    return model

if __name__ == "__main__":
